---
import { Image } from 'astro:assets';

import logoAustinGarden from '@images/logos/inn_cahoots_garden.webp';
import logoIykyk from '@images/logos/inn_cahoots_iykyk_rooftop.webp';
import logoLeftway from '@images/logos/leftway_studios.webp';
import logoStudio from '@images/logos/inn_cahoots_studio.webp';

import type { ImageMetadata } from 'astro';

interface Props {
    placeholders: string[];
    sponsors?: boolean;
}

interface Sponsor {
    alt: string;
    densities?: number[];
    image: ImageMetadata;
    invert?: boolean;
    photo?: boolean;
    width: number;
    zoom?: boolean;
}

const SPONSORS: Sponsor[] = [
    { alt: 'Austin Garden \u2014 Inn Cahoots', image: logoAustinGarden, photo: true, width: 225 },
    { alt: 'IYKYK Rooftop \u2014 Inn Cahoots', densities: [1, 2], image: logoIykyk, invert: true, width: 320, zoom: true },
    { alt: 'The Studio \u2014 Inn Cahoots', densities: [1, 2], image: logoStudio, invert: true, width: 320, zoom: true },
    { alt: 'Leftway Studios', densities: [1, 2], image: logoLeftway, invert: true, width: 320 },
];

const { placeholders, sponsors = false } = Astro.props;
---

<ul
    class="logo-wall list-none"
    data-reveal
>
    {sponsors && SPONSORS.map(sponsor => (
        <li class:list={['logo-tile', { 'logo-tile--photo': sponsor.photo }]}>
            <Image
                class:list={[
                    'logo-tile__image',
                    {
                        'logo-tile__image--invert': sponsor.invert,
                        'logo-tile__image--zoom': sponsor.zoom,
                    },
                ]}
                alt={sponsor.alt}
                densities={sponsor.densities}
                loading="lazy"
                src={sponsor.image}
                width={sponsor.width}
            />
        </li>
    ))}
    {placeholders.map(label => (
        <li class="logo-tile placeholder">
            <span>{label}</span>
        </li>
    ))}
</ul>

<style>
    .logo-tile {
        aspect-ratio: 16 / 9;
        background: var(--color-ink-2);
        border: var(--border-soft);
        border-radius: var(--radius-card-sm);
        overflow: hidden;
        position: relative;
        transition: border-color var(--duration-base), transform var(--duration-base);
    }

    .logo-tile:hover {
        border-color: var(--color-purple-55);
        transform: translateY(-0.3rem) rotate(-1deg);
    }

    .logo-tile--photo .logo-tile__image {
        height: 100%;
        inset: 0;
        object-fit: cover;
        width: 100%;
    }

    .logo-tile.placeholder {
        min-height: 0;
    }

    .logo-tile__image {
        height: calc(100% - 2.6rem);
        inset: 1.3rem;
        object-fit: contain;
        position: absolute;
        width: calc(100% - 2.6rem);
    }

    .logo-tile__image--invert {
        filter: invert(1);
        opacity: 0.92;
    }

    .logo-tile__image--zoom {
        transform: scale(1.35);
    }

    .logo-wall {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    }
</style>
