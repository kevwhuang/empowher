---

---

<section
    class="not-found"
    aria-labelledby="not-found-title"
>
    <div class="container">
        <p
            class="not-found__code"
            aria-hidden="true"
        >
            <span>4</span>
            <span>0</span>
            <span>4</span>
        </p>
        <h1 id="not-found-title">This page lost the plot</h1>
        <p class="not-found__lede">Whatever you were looking for isn't here &mdash; but the festival definitely is. Let's get you back to the music.</p>
        <div class="flex flex-wrap justify-center gap-4">
            <a
                class="btn btn--large btn--primary"
                href="/"
            >
                Take me home
            </a>
            <a
                class="btn btn--ghost btn--large"
                href="/contact"
            >
                Report a broken link
            </a>
        </div>
    </div>
</section>

<style>
    .not-found {
        display: grid;
        min-height: calc(100svh - var(--spacing-header));
        padding: clamp(3rem, 7vw, 5rem) 0;
        place-items: center;
        text-align: center;
    }

    .not-found p {
        color: var(--color-lavender);
        margin-inline: auto;
        max-width: 40ch;
    }

    .not-found__code {
        display: flex;
        font-family: var(--font-display);
        font-size: clamp(5rem, 18vw, 11rem);
        font-weight: 900;
        justify-content: center;
        letter-spacing: 0.02em;
        line-height: 1;
    }

    .not-found__code span:nth-child(1) {
        color: var(--color-purple);
        rotate: -7deg;
    }

    .not-found__code span:nth-child(2) {
        color: var(--color-pink);
        rotate: 4deg;
        translate: 0 -0.06em;
    }

    .not-found__code span:nth-child(3) {
        color: var(--color-cyan);
        rotate: -3deg;
    }

    .not-found__lede {
        margin-bottom: 2rem;
    }
</style>
