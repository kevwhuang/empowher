---
import { Image } from 'astro:assets';

import slide1 from '../images/slide_1.webp';
import slide2 from '../images/slide_2.webp';
import slide3 from '../images/slide_3.webp';
import slide4 from '../images/slide_4.webp';
---

<section class="flex flex-col items-center bg-black">
    <div class="flex w-full max-w-[1280px] flex-col gap-[clamp(1rem,0.333rem+3.333vw,3rem)] p-[clamp(1rem,0.333rem+3.333vw,3rem)_clamp(0.5rem,2.5vw,2rem)]">
        <Image class="w-full rounded-[clamp(0px,0.833vw-0.167rem,0.5rem)]" alt="EmpowHER ATX — November 8th, The Austin Garden, 12—10pm" src={slide1} />
        <Image class="w-full rounded-[clamp(0px,0.833vw-0.167rem,0.5rem)]" alt="What is EmpowHER — music production, community movement, live podcasts, authentic awareness" src={slide2} />
        <Image class="w-full rounded-[clamp(0px,0.833vw-0.167rem,0.5rem)]" alt="Three stages — The Secret Garden, Austin Garden Stage, The Studio" src={slide3} />
        <Image class="w-full rounded-[clamp(0px,0.833vw-0.167rem,0.5rem)]" alt="Join EmpowHER — Madewell Productions, annamadewell.com" src={slide4} />
    </div>
</section>
