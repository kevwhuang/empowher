---
import { Image } from 'astro:assets';

import logoEmpowher from '@images/logos/empowher_festival.webp';
import { ROUTES } from '@lib/utils';

const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="site-header">
    <div class="container site-header__inner">
        <a
            class="site-header__brand"
            aria-label="EmpowHER Festival &mdash; home"
            href="/"
        >
            <Image
                class="site-header__logo"
                alt=""
                densities={[1, 2]}
                src={logoEmpowher}
                width={77}
            />
        </a>
        <nav
            id="site-nav"
            class="site-nav"
            aria-label="Main"
        >
            {ROUTES.map(route => (
                <a
                    aria-current={pathname === route.href ? 'page' : undefined}
                    href={route.href}
                >
                    {route.label}
                </a>
            ))}
        </nav>
        <button
            class="nav-toggle"
            aria-controls="site-nav"
            aria-expanded="false"
            aria-label="Toggle menu"
            type="button"
        >
            <span aria-hidden="true" />
            <span aria-hidden="true" />
            <span aria-hidden="true" />
        </button>
    </div>
    <span class="holo-bar -bottom-[3px] inset-x-0" aria-hidden="true" />
</header>

<style>
    .nav-toggle {
        background: transparent;
        border: var(--border-soft);
        border-radius: var(--radius-card-sm);
        cursor: pointer;
        display: none;
        flex-direction: column;
        gap: 5px;
        height: 2.75rem;
        justify-content: center;
        padding: 0.6rem;
        position: relative;
        transition: background-color var(--duration-fast), border-color var(--duration-fast);
        width: 2.75rem;
    }

    .nav-toggle:active {
        background: var(--color-paper-10);
    }

    .nav-toggle:hover {
        border-color: var(--color-paper-40);
    }

    .nav-toggle::after {
        content: '';
        inset: -0.125rem;
        position: absolute;
    }

    .nav-toggle span {
        background: var(--color-paper);
        border-radius: 2px;
        height: 2px;
        transition: opacity var(--duration-fast), transform var(--duration-base);
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(2) {
        opacity: 0;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    .site-header {
        backdrop-filter: blur(14px);
        background: var(--color-ink-80);
        border-bottom: var(--border-soft);
        height: var(--spacing-header);
        position: sticky;
        top: 0;
        z-index: 100;
        -webkit-backdrop-filter: blur(14px);
    }

    .site-header__brand {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        margin-right: auto;
        text-decoration: none;
        user-select: none;
    }

    .site-header__inner {
        align-items: center;
        display: flex;
        gap: 1.5rem;
        height: 100%;
    }

    .site-header__logo {
        height: 2.4rem;
        width: auto;
    }

    .site-nav {
        align-items: center;
        display: flex;
        gap: clamp(0.2rem, 1vw, 0.8rem);
    }

    .site-nav a {
        border-radius: 999px;
        color: var(--color-lavender);
        font-family: var(--font-display);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        padding: 0.5rem 0.7rem;
        text-decoration: none;
        transition: background-color var(--duration-fast), color var(--duration-fast);
    }

    .site-nav a:hover {
        color: var(--color-paper);
    }

    .site-nav a[aria-current='page'] {
        background: var(--color-purple);
        color: var(--color-ink);
        font-weight: 700;
    }

    @media (max-width: 64rem) {
        .nav-toggle {
            display: flex;
        }

        .site-nav {
            align-items: stretch;
            backdrop-filter: blur(14px);
            background: var(--color-ink-95);
            border-bottom: var(--border-soft);
            flex-direction: column;
            gap: 0.25rem;
            inset: var(--spacing-header) 0 auto;
            padding: 1rem var(--gutter) 1.5rem;
            position: fixed;
            transform: translateY(-115%);
            transition: transform var(--duration-base), visibility 0s var(--duration-base);
            visibility: hidden;
        }

        .site-nav.is-open {
            transform: translateY(0);
            transition: transform var(--duration-base), visibility 0s;
            visibility: visible;
        }

        .site-nav a {
            font-size: 1rem;
            padding: 0.85rem 1rem;
        }
    }
</style>

<script>
    function handleMenuKeydown(event: KeyboardEvent) {
        const nav = document.getElementById('site-nav');

        if (!nav?.classList.contains('is-open')) return;

        if (event.key === 'Escape') {
            setMenuOpen(false);
            document.querySelector<HTMLElement>('.nav-toggle')?.focus();
        } else if (event.key === 'Tab') {
            const toggle = document.querySelector<HTMLElement>('.nav-toggle');

            if (toggle && isToggleVisible(toggle)) trapFocus(event, nav);
        }
    }

    function handleNavClick(event: Event) {
        if (event.target instanceof Element && event.target.closest('a')) setMenuOpen(false);
    }

    function initNavbar() {
        const nav = document.getElementById('site-nav');
        const toggle = document.querySelector('.nav-toggle');

        if (!nav || !toggle) return;

        nav.addEventListener('click', handleNavClick);
        toggle.addEventListener('click', () => setMenuOpen(toggle.getAttribute('aria-expanded') !== 'true'));
    }

    function isToggleVisible(toggle: HTMLElement) {
        return getComputedStyle(toggle).display !== 'none';
    }

    function setMenuOpen(open: boolean) {
        const nav = document.getElementById('site-nav');
        const toggle = document.querySelector<HTMLElement>('.nav-toggle');

        nav?.classList.toggle('is-open', open);
        toggle?.setAttribute('aria-expanded', String(open));

        if (!open || !nav || !toggle || !isToggleVisible(toggle)) return;

        requestAnimationFrame(() => {
            requestAnimationFrame(() => nav.querySelector<HTMLElement>('a')?.focus());
        });
    }

    function trapFocus(event: KeyboardEvent, nav: HTMLElement) {
        const focusables = nav.querySelectorAll<HTMLElement>('a');
        const first = focusables[0];
        const last = focusables[focusables.length - 1];

        if (event.shiftKey && document.activeElement === first) {
            event.preventDefault();
            last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
            event.preventDefault();
            first.focus();
        }
    }

    document.addEventListener('astro:page-load', initNavbar);
    document.addEventListener('keydown', handleMenuKeydown);
</script>
