---
import { Image } from 'astro:assets';

import SectionHead from '@components/SectionHead.astro';
import logoAustinGarden from '@images/logos/austin_garden.webp';
import logoIykyk from '@images/logos/iykyk.webp';
import logoStudio from '@images/logos/the_studio.webp';

import type { ImageMetadata } from 'astro';

interface Props {
    variant?: 'home' | 'info';
}

interface Stage {
    descriptions: Record<'home' | 'info', string>;
    invert?: boolean;
    logo: ImageMetadata;
    logoAlt: string;
    name: string;
    vibe: string;
    width: number;
}

const STAGES: Stage[] = [
    {
        descriptions: {
            home: 'Rooftop home of acoustic acts \u00B7 tattoos \u00B7 tarot \u00B7 immersive experiences \u2014 AKA the IYKYK Rooftop',
            info: 'AKA the IYKYK Rooftop \u2014 Acoustic acts \u00B7 Tattoos \u00B7 Tarot \u00B7 Sunset sets \u00B7 Skyline views \u00B7 Immersive experiences',
        },
        invert: true,
        logo: logoIykyk,
        logoAlt: 'IYKYK \u2014 Inn Cahoots',
        name: 'Secret Garden',
        vibe: 'Vibe: Mystical \u00B7 Intimate \u00B7 Golden hour',
        width: 74,
    },
    {
        descriptions: {
            home: 'Main acts + DJ headliners',
            info: 'Main acts + DJ headliners',
        },
        logo: logoAustinGarden,
        logoAlt: 'Austin Garden',
        name: 'Austin Garden Stage',
        vibe: 'Vibe: High-energy \u00B7 Open-air \u00B7 Peak visibility',
        width: 42,
    },
    {
        descriptions: {
            home: 'Podcasts \u00B7 Comedians \u00B7 Live bands \u00B7 Solo artists',
            info: 'Podcasts \u00B7 Comedians \u00B7 Live bands \u00B7 Solo artists \u00B7 Storytelling brands',
        },
        invert: true,
        logo: logoStudio,
        logoAlt: 'The Studio \u2014 Inn Cahoots',
        name: 'The Studio',
        vibe: 'Vibe: Intimate \u00B7 Conversational \u00B7 Content-driven',
        width: 74,
    },
];

const { variant = 'home' } = Astro.props;
const isInfo = variant === 'info';
---

<section
    class:list={['section', { 'section--tint': isInfo }]}
    aria-labelledby="stages-title"
>
    <div class="container">
        <SectionHead
            eyebrow="The spaces"
            headingId="stages-title"
        >
            Three stages. One immersive experience.
        </SectionHead>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(17rem,1fr))] gap-[1.2rem]">
            {STAGES.map((stage, index) => (
                <article
                    class="card stage-card"
                    data-reveal
                    style={index ? `--reveal-i: ${index};` : undefined}
                >
                    <div class="ph">
                        <span>photo</span>
                    </div>
                    <div class="stage-card__body">
                        <h3>{stage.name}</h3>
                        <p>{stage.descriptions[variant]}</p>
                        <p class="stage-card__vibe">{stage.vibe}</p>
                        {isInfo && (
                            <Image
                                class:list={['stage-card__logo', { 'stage-card__logo--invert': stage.invert }]}
                                alt={stage.logoAlt}
                                densities={[1, 2]}
                                loading="lazy"
                                src={stage.logo}
                                width={stage.width}
                            />
                        )}
                    </div>
                </article>
            ))}
        </div>
        {!isInfo && (
            <p
                class="mt-8"
                data-reveal
            >
                <a
                    class="btn btn--ghost"
                    href="/info"
                >
                    Full festival info &rarr;
                </a>
            </p>
        )}
    </div>
</section>

<style>
    .stage-card {
        display: flex;
        flex-direction: column;
        overflow: clip;
        padding: 0;
    }

    .stage-card .ph {
        aspect-ratio: 16 / 10;
        border: 0;
        border-bottom: var(--border-soft);
        border-radius: 0;
    }

    .stage-card__body {
        display: grid;
        flex: 1;
        gap: 0.5rem;
        padding: clamp(1.3rem, 2.5vw, 1.8rem);
    }

    .stage-card__body .stage-card__vibe {
        color: var(--color-yellow);
        font-family: var(--font-ransom);
        font-size: 0.82rem;
        letter-spacing: 0.12em;
        margin-top: auto;
        text-transform: uppercase;
    }

    .stage-card__logo {
        height: 2.6rem;
        object-fit: contain;
        width: auto;
    }

    .stage-card__logo--invert {
        filter: invert(1);
        opacity: 0.92;
    }
</style>
