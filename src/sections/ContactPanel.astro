---
import { LINKS } from '@lib/utils';

const CARDS = [
    { href: `mailto:${LINKS.email}`, icon: '\u2709', title: 'Email', value: LINKS.email },
    { external: true, href: LINKS.instagram, icon: '\u2726', title: 'Instagram', value: LINKS.instagramHandle },
    { external: true, href: LINKS.website, icon: '\u2665', title: 'Website', value: LINKS.websiteLabel },
];
---

<section
    class="section"
    aria-labelledby="reach-title"
>
    <div class="container">
        <h2
            id="reach-title"
            class="sr-only"
        >
            Ways to reach us
        </h2>
        <div class="contact-grid">
            <ul class="grid gap-4 list-none">
                {CARDS.map((card, index) => (
                    <li>
                        <a
                            class="card contact-card"
                            data-reveal
                            href={card.href}
                            rel={card.external ? 'noopener noreferrer' : undefined}
                            style={index ? `--reveal-index: ${index};` : undefined}
                            target={card.external ? '_blank' : undefined}
                        >
                            <span
                                class="contact-card__icon"
                                aria-hidden="true"
                            >
                                {card.icon}
                            </span>
                            <div class="contact-card__body">
                                <h3>{card.title}</h3>
                                <p>{card.value}</p>
                            </div>
                        </a>
                    </li>
                ))}
            </ul>
            <div
                class="card"
                data-reveal
            >
                <h2 class="text-h3">Send a message</h2>
                <form
                    class="contact-form grid gap-[1.1rem]"
                    novalidate
                >
                    <div class="contact-form__row">
                        <label class="field">
                            <span>Name</span>
                            <input autocomplete="name" name="name" required type="text" />
                        </label>
                        <label class="field">
                            <span>Email</span>
                            <input autocomplete="email" name="email" required type="email" />
                        </label>
                    </div>
                    <label class="field">
                        <span>I'm reaching out about</span>
                        <select
                            name="topic"
                            required
                        >
                            <option
                                disabled
                                selected
                                value=""
                            >
                                Choose a topic&hellip;
                            </option>
                            <option value="performing">Performing</option>
                            <option value="press">Press &amp; media</option>
                            <option value="other">Something else</option>
                            <option value="sponsorship">Sponsorship</option>
                            <option value="tickets">Tickets</option>
                            <option value="vending">Vending</option>
                            <option value="volunteering">Volunteering</option>
                        </select>
                    </label>
                    <label class="field">
                        <span>Message</span>
                        <textarea name="message" required />
                    </label>
                    <button
                        class="btn btn--large btn--primary"
                        type="submit"
                    >
                        Send it &#x2726;
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
    .card {
        --reveal-index: 2;
    }

    .contact-card {
        align-items: center;
        display: flex;
        gap: 1.1rem;
        text-decoration: none;
    }

    .contact-card__body h3 {
        color: var(--color-lavender);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        margin-bottom: 0.15rem;
        text-transform: uppercase;
    }

    .contact-card__body p {
        color: var(--color-paper);
        font-weight: 600;
        word-break: break-word;
    }

    .contact-card__icon {
        background: var(--color-purple-15);
        border-radius: 999px;
        color: var(--color-purple);
        display: grid;
        flex-shrink: 0;
        font-size: 1.2rem;
        height: 3rem;
        place-items: center;
        width: 3rem;
    }

    .contact-form__row {
        display: grid;
        gap: 1.1rem;
        grid-template-columns: 1fr 1fr;
    }

    :global(.contact-form__success) {
        background: var(--color-cyan-15);
        border: 1px solid var(--color-cyan-40);
        border-radius: var(--radius-card-sm);
        color: var(--color-cyan);
        font-weight: 600;
        padding: 1rem 1.3rem;
    }

    .contact-grid {
        align-items: start;
        display: grid;
        gap: clamp(2rem, 5vw, 4rem);
        grid-template-columns: 1fr 1.3fr;
    }

    .field {
        display: grid;
        gap: 0.4rem;
    }

    .field > span {
        color: var(--color-lavender);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    .field input,
    .field select,
    .field textarea {
        background: var(--color-ink-2);
        border: 1px solid var(--color-paper-35);
        border-radius: var(--radius-card-sm);
        color: var(--color-paper);
        padding: 0.85rem 1rem;
        transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
        width: 100%;
    }

    .field input:focus-visible,
    .field select:focus-visible,
    .field textarea:focus-visible {
        border-color: var(--color-purple);
        box-shadow: 0 0 0 3px var(--color-purple-25);
        outline: none;
    }

    .field input:hover,
    .field select:hover,
    .field textarea:hover {
        border-color: var(--color-paper-40);
    }

    .field select {
        cursor: pointer;
    }

    .field textarea {
        min-height: 8rem;
        resize: vertical;
    }

    @media (max-width: 48rem) {
        .contact-form__row {
            grid-template-columns: 1fr;
        }

        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    function handleSubmit(event: SubmitEvent) {
        event.preventDefault();

        const form = event.currentTarget;

        if (!(form instanceof HTMLFormElement) || !form.reportValidity()) return;

        const success = document.createElement('p');

        success.className = 'contact-form__success';
        success.setAttribute('role', 'status');
        success.textContent = 'Got it! We\'ll get back to you soon. \u{1F49C}';
        form.replaceWith(success);
    }

    function initContactForm() {
        const form = document.querySelector<HTMLFormElement>('.contact-form');

        form?.addEventListener('submit', handleSubmit);
    }

    document.addEventListener('astro:page-load', initContactForm);
</script>
