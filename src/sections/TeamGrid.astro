---
import SectionHead from '@components/SectionHead.astro';

const REVEAL_CYCLE = 4;
const ROLES = [
    'Hospitality',
    'Marketing & Socials',
    'Production',
    'Safety',
    'Sponsorships & Vendors',
    'Stage Management',
    'Talent & Booking',
    'Volunteers',
];
---

<section
    class="section"
    aria-labelledby="team-title"
>
    <div class="container">
        <SectionHead
            eyebrow="Operational team"
            headingId="team-title"
        >
            The hands and hearts behind it
            <p slot="text">Meet the leads &mdash; with dozens more across stages, production, hospitality, and safety.</p>
        </SectionHead>
        <ul class="grid grid-cols-[repeat(auto-fill,minmax(13rem,1fr))] gap-[1.2rem] list-none">
            {ROLES.map((role, index) => (
                <li
                    class="card team-card"
                    data-reveal
                    style={index % REVEAL_CYCLE ? `--reveal-index: ${index % REVEAL_CYCLE};` : undefined}
                >
                    <div class="placeholder">
                        <span>photo</span>
                    </div>
                    <div class="team-card__body">
                        <h3>Name Placeholder</h3>
                        <p>{role}</p>
                    </div>
                </li>
            ))}
        </ul>
    </div>
</section>

<style>
    .team-card {
        overflow: clip;
        padding: 0;
        text-align: center;
    }

    .team-card .placeholder {
        aspect-ratio: 1;
        border: 0;
        border-bottom: var(--border-soft);
        border-radius: 0;
    }

    .team-card__body {
        padding: 1.1rem 1rem 1.3rem;
    }

    .team-card__body h3 {
        font-size: 0.98rem;
        margin-bottom: 0.2rem;
    }

    .team-card__body p {
        font-size: 0.85rem;
    }
</style>
