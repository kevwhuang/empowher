---
import SectionHead from '@components/SectionHead.astro';

interface ScheduleRow {
    description: string;
    time: string;
    title: string;
    where: string;
}

const SCHEDULE: ScheduleRow[] = [
    {
        description: 'Panelists kick off EmpowHER with stories of authenticity and resilience.',
        time: '12PM',
        title: 'Doors + Live Podcast Session',
        where: 'The Studio',
    },
    {
        description: 'Ecstatic dance, spoken word, tattoos, and immersive experiences.',
        time: 'Afternoon',
        title: 'Acoustic Sets, Tarot + Workshops',
        where: 'Secret Garden',
    },
    {
        description: 'Skyline views and sundown DJs before the headliners take over.',
        time: 'Sunset',
        title: 'Golden Hour Sets',
        where: 'Secret Garden',
    },
    {
        description: 'Flash mobs, LED + fire flow shows, and the night\'s biggest sets until 10PM.',
        time: 'Evening',
        title: 'Main Acts + DJ Headliners',
        where: 'Austin Garden Stage',
    },
];
---

<section
    class="section"
    aria-labelledby="schedule-title"
>
    <div class="container">
        <SectionHead
            eyebrow="Day-of flow"
            headingId="schedule-title"
        >
            The shape of the day
            <p slot="text">Lineup and set times drop soon &mdash; here's how the day flows.</p>
        </SectionHead>
        <ol class="schedule grid gap-[0.8rem]">
            {SCHEDULE.map((row, index) => (
                <li
                    class="card schedule__row"
                    data-reveal
                    style={index ? `--reveal-i: ${index};` : undefined}
                >
                    <span class="schedule__time">{row.time}</span>
                    <div class="schedule__what">
                        <h3>{row.title}</h3>
                        <p>{row.description}</p>
                    </div>
                    <span class="schedule__where">{row.where}</span>
                </li>
            ))}
        </ol>
    </div>
</section>

<style>
    .schedule__row {
        align-items: center;
        display: grid;
        gap: 1rem;
        grid-template-columns: 7.5rem 1fr auto;
        padding: 1.1rem 1.4rem;
    }

    .schedule__time {
        color: var(--color-purple-bright);
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 700;
    }

    .schedule__what h3 {
        font-size: 1rem;
        margin-bottom: 0.15rem;
    }

    .schedule__what p {
        font-size: 0.9rem;
    }

    .schedule__where {
        color: var(--color-cyan);
        font-family: var(--font-ransom);
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    @media (max-width: 40rem) {
        .schedule__row {
            gap: 0.3rem;
            grid-template-columns: 1fr;
        }
    }
</style>
