---
import { Image } from 'astro:assets';

import logoEmpowher from '@images/logos/empowher_festival.webp';
import poster from '@images/poster.webp';
---

<section
    class="hero"
    aria-labelledby="hero-title"
>
    <div
        class="hero__media"
        aria-hidden="true"
    >
        <video
            autoplay
            loop
            muted
            playsinline
            poster={poster.src}
        >
            <source src="/videos/hero.webm" type="video/webm" />
        </video>
    </div>
    <div class="container relative z-1">
        <h1 id="hero-title">
            <Image
                class="hero__logo"
                alt="EmpowHER Festival"
                densities={[1, 2]}
                fetchpriority="high"
                loading="eager"
                src={logoEmpowher}
                width={544}
            />
        </h1>
        <p
            class="hero__tagline"
            data-reveal
        >
            A storytelling immersive music production that reminds you <strong>who TF you are</strong>. Empowering voices.
        </p>
        <p
            class="hero__meta"
            data-reveal
        >
            <span><time datetime="2026-11-08">November 8</time></span>
            <span
                class="hero__meta-dot"
                aria-hidden="true"
            >
                &#x2726;
            </span>
            <span>12PM&ndash;10PM</span>
            <span
                class="hero__meta-dot"
                aria-hidden="true"
            >
                &#x2726;
            </span>
            <span>Austin Garden</span>
        </p>
        <p
            class="hero__spaces"
            data-reveal
        >
            Garden Stage &bull; IYKYK Rooftop &bull; The Studio
        </p>
        <div
            class="hero__actions"
            data-reveal
        >
            <a
                class="btn btn--large btn--primary"
                href="/contact"
            >
                Become a Sponsor
            </a>
            <a
                class="btn btn--ghost btn--large"
                href="/info"
            >
                Explore the Festival
            </a>
        </div>
    </div>
    <a
        class="hero__scroll"
        href="#countdown"
    >
        Scroll &darr;
    </a>
</section>

<style>
    .hero {
        display: grid;
        min-height: calc(100svh - var(--spacing-header));
        overflow: clip;
        padding: clamp(3.5rem, 7.5vw, 6rem) 0;
        place-items: center;
        position: relative;
        text-align: center;
    }

    .hero h1 {
        margin-bottom: 1.4rem;
        user-select: none;
    }

    .hero__actions {
        --reveal-index: 3;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

    .hero__logo {
        filter: drop-shadow(0 0.8rem 2.5rem var(--color-purple-45));
        margin-inline: auto;
        width: min(34rem, 84vw);
    }

    .hero__media {
        background:
            radial-gradient(60% 80% at 25% 25%, var(--color-purple-40), transparent 65%),
            radial-gradient(55% 70% at 78% 30%, var(--color-pink-25), transparent 65%),
            radial-gradient(50% 65% at 50% 90%, var(--color-cyan-20), transparent 65%),
            var(--color-ink);
        inset: 0;
        position: absolute;
        z-index: 0;
    }

    .hero__media::after {
        background: linear-gradient(180deg, var(--color-ink-55), var(--color-ink-80) 80%, var(--color-ink));
        content: '';
        inset: 0;
        position: absolute;
    }

    .hero__media video {
        height: 100%;
        object-fit: cover;
        width: 100%;
    }

    .hero__meta {
        --reveal-index: 1;
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        font-family: var(--font-display);
        font-size: clamp(0.82rem, 1.5vw, 1rem);
        font-weight: 700;
        gap: 0.5rem 1rem;
        justify-content: center;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .hero__meta-dot {
        color: var(--color-pink);
    }

    .hero__scroll {
        animation: hero__scroll-hint 2.4s ease-in-out infinite;
        bottom: 1.4rem;
        color: var(--color-lavender);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        left: 50%;
        letter-spacing: 0.25em;
        position: absolute;
        text-decoration: none;
        text-transform: uppercase;
        transition: color var(--duration-fast);
        translate: -50%;
        z-index: 1;
    }

    .hero__scroll:hover {
        color: var(--color-paper);
    }

    .hero__spaces {
        --reveal-index: 2;
        color: var(--color-cyan);
        font-family: var(--font-mono);
        font-size: clamp(0.8rem, 1.4vw, 0.95rem);
        letter-spacing: 0.14em;
        margin-bottom: 2.4rem;
        text-transform: uppercase;
    }

    .hero__tagline {
        font-size: clamp(1.05rem, 2vw, 1.4rem);
        font-weight: 500;
        margin-bottom: 1.6rem;
        margin-inline: auto;
        max-width: 44ch;
    }

    .hero__tagline strong {
        color: var(--color-purple);
    }

    @keyframes hero__scroll-hint {
        0%,
        100% {
            opacity: 0.7;
            transform: translateY(0);
        }

        50% {
            opacity: 1;
            transform: translateY(0.45rem);
        }
    }
</style>
