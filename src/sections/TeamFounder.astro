---
import SectionHead from '@components/SectionHead.astro';
import { LINKS } from '@lib/utils';
---

<section
    class="section section--tint"
    aria-labelledby="founder-title"
>
    <div class="container">
        <div class="founder">
            <div
                class="placeholder"
                data-reveal
            >
                <span>photo</span>
            </div>
            <div
                class="founder__content"
                data-reveal
            >
                <SectionHead
                    eyebrow="Founder spotlight"
                    headingId="founder-title"
                >
                    Anna Madewell
                    <p
                        class="founder__role"
                        slot="text"
                    >
                        Founder &amp; Executive Director &middot; Madewell Productions
                    </p>
                </SectionHead>
                <p>The director behind EmpowHER Festival, Anna leads Madewell Productions in cross-collaboration with Austin's creative collectives &mdash; turning one venue, three stages, and a 40+ person team into a storytelling immersive music production.</p>
                <p class="founder__impact">Under her direction, EmpowHER 2025 generated $10,000+ in cash sponsorships and ticket revenue while building a growing movement around authenticity and self-expression.</p>
                <div class="flex flex-wrap gap-4">
                    <a
                        class="btn btn--primary"
                        href={LINKS.website}
                        rel="noopener noreferrer"
                        target="_blank"
                    >
                        {LINKS.websiteLabel}
                    </a>
                    <a
                        class="btn btn--ghost"
                        href="/contact"
                    >
                        Work with us
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .founder {
        align-items: center;
        display: grid;
        gap: clamp(2rem, 5vw, 4rem);
        grid-template-columns: minmax(15rem, 24rem) 1fr;
    }

    .founder .placeholder {
        aspect-ratio: 4 / 5;
        box-shadow: var(--shadow-pop-purple);
        rotate: -2deg;
    }

    .founder__content {
        --reveal-index: 1;
    }

    .founder__impact {
        margin-bottom: 1.6rem;
    }

    .founder__role {
        color: var(--color-pink);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    @media (max-width: 48rem) {
        .founder {
            grid-template-columns: 1fr;
        }
    }
</style>
