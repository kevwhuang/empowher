---
import SectionHead from '@components/SectionHead.astro';

const EVENT_DATE = '2026-11-08T12:00:00-06:00';

const UNITS = [
    { label: 'Days', unit: 'days' },
    { label: 'Hours', unit: 'hours' },
    { label: 'Minutes', unit: 'minutes' },
    { label: 'Seconds', unit: 'seconds' },
];
---

<section
    id="countdown"
    class="section text-center"
    aria-labelledby="countdown-title"
>
    <div class="container">
        <SectionHead
            center
            eyebrow="The clock is ticking"
            headingId="countdown-title"
        >
            EmpowHER goes live in
        </SectionHead>
        <ul
            class="countdown list-none"
            aria-label="Event countdown"
            aria-live="off"
            data-countdown={EVENT_DATE}
            data-reveal
            role="timer"
        >
            {UNITS.map(({ label, unit }) => (
                <li class="countdown__unit">
                    <span
                        class="countdown__number"
                        data-unit={unit}
                    >
                        --
                    </span>
                    <span class="countdown__label">{label}</span>
                </li>
            ))}
        </ul>
    </div>
</section>

<style>
    .countdown {
        --reveal-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.7rem, 2.5vw, 1.6rem);
        justify-content: center;
        user-select: none;
    }

    .countdown__label {
        color: var(--color-lavender);
        font-family: var(--font-mono);
        font-size: 0.85rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }

    .countdown__number {
        background: var(--color-ink-2);
        border: var(--border-soft);
        border-radius: var(--radius-card-sm);
        box-shadow: var(--shadow-pop-purple);
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 7vw, 4.5rem);
        font-variant-numeric: tabular-nums;
        font-weight: 900;
        line-height: 1;
        min-width: 2ch;
        padding: 0.45em 0.6em;
    }

    .countdown__number.is-tick {
        animation: countdown__tick 0.45s var(--ease-pop);
    }

    .countdown__unit {
        display: grid;
        gap: 0.4rem;
        justify-items: center;
    }

    @keyframes countdown__tick {
        0% {
            opacity: 0.2;
            transform: translateY(-0.35em);
        }

        100% {
            opacity: 1;
            transform: none;
        }
    }
</style>

<script>
    import { pad } from '@lib/utils';

    const MS_PER_SECOND = 1_000;
    const SECONDS_PER_DAY = 86_400;
    const SECONDS_PER_HOUR = 3_600;
    const SECONDS_PER_MINUTE = 60;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let countdownInterval: Timer | undefined;

    function initCountdown() {
        clearInterval(countdownInterval);

        const root = document.querySelector<HTMLElement>('[data-countdown]');

        if (!root) return;

        const days = root.querySelector<HTMLElement>('[data-unit="days"]');
        const hours = root.querySelector<HTMLElement>('[data-unit="hours"]');
        const minutes = root.querySelector<HTMLElement>('[data-unit="minutes"]');
        const seconds = root.querySelector<HTMLElement>('[data-unit="seconds"]');
        const target = new Date(root.dataset.countdown ?? '').getTime();

        if (Number.isNaN(target)) return;

        function update() {
            const remaining = Math.max(0, target - Date.now());
            const total = Math.floor(remaining / MS_PER_SECOND);

            setValue(days, Math.floor(total / SECONDS_PER_DAY));
            setValue(hours, Math.floor((total % SECONDS_PER_DAY) / SECONDS_PER_HOUR));
            setValue(minutes, Math.floor((total % SECONDS_PER_HOUR) / SECONDS_PER_MINUTE));
            setValue(seconds, total % SECONDS_PER_MINUTE);
        }

        update();
        countdownInterval = setInterval(update, MS_PER_SECOND);
    }

    function setValue(element: HTMLElement | null, value: number) {
        const text = pad(value);

        if (!element || element.textContent === text) return;

        element.textContent = text;

        if (element.dataset.unit === 'seconds' || prefersReducedMotion) return;

        element.classList.remove('is-tick');
        void element.offsetWidth;
        element.classList.add('is-tick');
    }

    document.addEventListener('astro:page-load', initCountdown);
</script>
