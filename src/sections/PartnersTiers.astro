---
import SectionHead from '@components/SectionHead.astro';

interface Tier {
    benefits: string[];
    featured?: boolean;
    name: string;
    tag: string;
    tagModifier: string;
}

const TIERS: Tier[] = [
    {
        benefits: [
            'Logo on site + festival signage',
            'Social media shout-outs',
            'Vendor booth option',
        ],
        name: 'The Spark',
        tag: 'Supporter',
        tagModifier: 'card__tag--cyan',
    },
    {
        benefits: [
            'Everything in The Spark',
            'Stage naming + MC mentions',
            'Logo on screens between sets',
            'Branded activation space',
        ],
        featured: true,
        name: 'The Amplifier',
        tag: 'Most popular',
        tagModifier: 'card__tag--pink',
    },
    {
        benefits: [
            'Everything in The Amplifier',
            'Presenting sponsor billing',
            'Live podcast segment integration',
            'First right of renewal for next year',
        ],
        name: 'The Powerhouse',
        tag: 'Headline',
        tagModifier: 'card__tag--yellow',
    },
];
---

<section
    class="section"
    aria-labelledby="tiers-title"
>
    <div class="container">
        <SectionHead
            eyebrow="Sponsorship tiers"
            headingId="tiers-title"
        >
            Pick your level of loud
            <p slot="text">Custom packages available &mdash; these are starting points, not boxes.</p>
        </SectionHead>
        <ul class="grid grid-cols-[repeat(auto-fit,minmax(16rem,1fr))] items-stretch gap-[1.2rem] list-none">
            {TIERS.map((tier, index) => (
                <li
                    class:list={['card', 'tier', { 'tier--featured': tier.featured }]}
                    data-reveal
                    style={index ? `--reveal-index: ${index};` : undefined}
                >
                    <span class:list={['card__tag', tier.tagModifier]}>{tier.tag}</span>
                    <h3>{tier.name}</h3>
                    <p class="tier__price">Inquire</p>
                    <ul>
                        {tier.benefits.map(benefit => (
                            <li>{benefit}</li>
                        ))}
                    </ul>
                    <a
                        class:list={['btn', tier.featured ? 'btn--primary' : 'btn--ghost']}
                        href="/contact"
                    >
                        Inquire
                    </a>
                </li>
            ))}
        </ul>
    </div>
</section>

<style>
    .tier {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .tier .tier__price {
        color: var(--color-purple);
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 900;
        margin-bottom: 0.6rem;
    }

    .tier li {
        align-items: baseline;
        display: flex;
        gap: 0.6em;
    }

    .tier li::before {
        color: var(--color-pink);
        content: '\2726';
        content: '\2726' / '';
        flex-shrink: 0;
    }

    .tier ul {
        align-content: start;
        color: var(--color-lavender);
        display: grid;
        flex: 1;
        font-size: 0.95rem;
        gap: 0.55rem;
        margin-bottom: 1.4rem;
    }

    .tier--featured {
        border-color: var(--color-purple-65);
        box-shadow: var(--shadow-glow-purple);
    }
</style>
