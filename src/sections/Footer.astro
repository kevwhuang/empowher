---
import { Image } from 'astro:assets';

import logoEmpowher from '@images/logos/empowher_festival.webp';
import logoMadewell from '@images/logos/madewell_productions.webp';
import { LINKS, ROUTES } from '@lib/utils';
---

<footer class="site-footer">
    <span class="holo-bar -top-[3px] inset-x-0" aria-hidden="true" />
    <div class="container">
        <div class="site-footer__grid">
            <div>
                <Image
                    class="site-footer__logo"
                    alt="EmpowHER Festival"
                    densities={[1, 2]}
                    src={logoEmpowher}
                    width={102}
                />
                <p class="site-footer__blurb">A storytelling immersive music production that reminds you who TF you are. Empowering voices.</p>
            </div>
            <div>
                <h2 class="site-footer__heading">Explore</h2>
                <ul>
                    {ROUTES.map(route => (
                        <li><a href={route.href}>{route.label}</a></li>
                    ))}
                </ul>
            </div>
            <div>
                <h2 class="site-footer__heading">Connect</h2>
                <ul>
                    <li><a href={`mailto:${LINKS.email}`}>{LINKS.email}</a></li>
                    <li>
                        <a
                            href={LINKS.instagram}
                            rel="noopener noreferrer"
                            target="_blank"
                        >
                            Instagram &mdash; {LINKS.instagramHandle}
                        </a>
                    </li>
                    <li>
                        <a
                            href={LINKS.website}
                            rel="noopener noreferrer"
                            target="_blank"
                        >
                            {LINKS.websiteLabel}
                        </a>
                    </li>
                </ul>
            </div>
            <div>
                <h2 class="site-footer__heading">Assets</h2>
                <ul>
                    <li>
                        <a
                            download
                            href={LINKS.pitchDeck}
                        >
                            Pitch deck
                        </a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="site-footer__legal">
            <span>&copy; {new Date().getFullYear()} EmpowHER Festival. All rights reserved.</span>
            <nav
                class="inline-flex gap-[1.2rem]"
                aria-label="Legal"
            >
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
            </nav>
            <span class="site-footer__madewell">
                Directed by Anna Madewell
                <Image
                    alt="Madewell Productions"
                    densities={[1, 2]}
                    src={logoMadewell}
                    width={43}
                />
            </span>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: var(--color-ink-2);
        border-top: var(--border-soft);
        padding: clamp(3rem, 6vw, 4.5rem) 0 2rem;
        position: relative;
    }

    .site-footer a {
        color: var(--color-lavender);
        text-decoration: none;
        transition: color var(--duration-fast);
    }

    .site-footer a:hover {
        color: var(--color-purple-bright);
    }

    .site-footer ul {
        display: grid;
        gap: 0.55rem;
    }

    .site-footer__blurb {
        color: var(--color-lavender);
        font-size: 0.95rem;
        max-width: 30ch;
    }

    .site-footer__grid {
        display: grid;
        gap: clamp(2rem, 5vw, 4rem);
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        margin-bottom: 3rem;
    }

    .site-footer__heading {
        color: var(--color-paper);
        font-size: 0.85rem;
        letter-spacing: 0.1em;
        margin-bottom: 1.1rem;
        text-transform: uppercase;
    }

    .site-footer__legal {
        align-items: center;
        border-top: var(--border-soft);
        color: var(--color-lavender);
        display: flex;
        flex-wrap: wrap;
        font-size: 0.85rem;
        gap: 1rem;
        justify-content: space-between;
        padding-top: 1.6rem;
    }

    .site-footer__logo {
        height: 3.2rem;
        margin-bottom: 1rem;
        user-select: none;
        width: auto;
    }

    .site-footer__madewell {
        align-items: center;
        display: inline-flex;
        gap: 0.6rem;
        user-select: none;
    }

    .site-footer__madewell img {
        filter: invert(1);
        height: 1.9rem;
        opacity: 0.85;
        width: auto;
    }

    @media (max-width: 64rem) {
        .site-footer__grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 48rem) {
        .site-footer__grid {
            grid-template-columns: 1fr;
        }
    }
</style>
