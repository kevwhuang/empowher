---
import CtaBanner from '@sections/CtaBanner.astro';
import Layout from '@/Layout.astro';
import PageHero from '@sections/PageHero.astro';
import StoreGrid from '@sections/StoreGrid.astro';
import { LINKS } from '@lib/utils';
---

<Layout
    description="The official EmpowHER Festival store &mdash; wear the movement and rep empowering voices ahead of November 8 at Austin Garden."
    title="Store &mdash; EmpowHER Festival"
>
    <PageHero
        eyebrow="Merch"
        text="Official EmpowHER Festival merch."
    >
        Wear the <span class="text-holo">movement</span>
    </PageHero>
    <StoreGrid />
    <CtaBanner
        eyebrow="Questions?"
        text="Questions about merch, sizing, or orders &mdash; reach out anytime."
        tint
    >
        We're happy to help
        <Fragment slot="actions">
            <a
                class="btn btn--large btn--primary"
                href="/contact"
            >
                Contact us
            </a>
            <a
                class="btn btn--ghost btn--large"
                href={LINKS.instagram}
                rel="noopener noreferrer"
                target="_blank"
            >
                DM on Instagram
            </a>
        </Fragment>
    </CtaBanner>
</Layout>
